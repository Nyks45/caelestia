#!/usr/bin/env python3
import json
import subprocess
import os
import time

STATE_FILE = "/tmp/caelestia-show-desktop.json"

def hyprctl(*args):
    subprocess.run(["hyprctl"] + list(args), capture_output=True)

def get_json(cmd):
    return json.loads(subprocess.run(["hyprctl", cmd, "-j"], capture_output=True, text=True).stdout)

def show_desktop():
    active = get_json("activeworkspace")
    ws_id = active["id"]
    mon_id = active["monitorID"]
    mon_name = active["monitor"]

    clients = get_json("clients")
    windows = [(c["address"], ws_id, mon_id, mon_name, c.get("at", [0, 0]), c.get("size", [0, 0]), c.get("floating", False)) for c in clients if c["workspace"]["id"] == ws_id and not c["hidden"] and c["mapped"]]

    if not windows:
        return

    cmds = [f"dispatch movetoworkspacesilent name:desktop,address:{addr}" for addr, *rest in windows]
    hyprctl("--batch", ";".join(cmds))

    with open(STATE_FILE, "w") as f:
        json.dump({"windows": windows, "workspace": ws_id}, f)

    # Write address → original workspace mapping for workspace dot icons
    mapping = {addr.replace("0x", ""): str(orig_ws) for addr, orig_ws, *_ in windows}
    with open("/tmp/caelestia-desktop-mapping.json", "w") as f:
        json.dump(mapping, f)

    # Write window details for the popout window list
    popout_windows = []
    for c in clients:
        if c["workspace"]["id"] == ws_id and not c["hidden"] and c["mapped"]:
            popout_windows.append({
                "address": c["address"].replace("0x", ""),
                "title": c.get("title", ""),
                "class": c.get("class", "")
            })
    with open("/tmp/caelestia-desktop-windows.json", "w") as f:
        json.dump(popout_windows, f)

    mapping = {w["address"].replace("0x", ""): str(ws_id) for w in windows}
    with open("/tmp/caelestia-desktop-mapping.json", "w") as f:
        json.dump(mapping, f)

    popout = [{"address": w["address"].replace("0x", ""), "title": "", "class": ""} for w in windows]
    with open("/tmp/caelestia-desktop-windows.json", "w") as f:
        json.dump(popout, f)

def restore():
    if not os.path.exists(STATE_FILE):
        return

    with open(STATE_FILE) as f:
        state = json.load(f)

    windows = state.get("windows", [])
    ws_id = state.get("workspace", 1)

    os.remove(STATE_FILE)
    for f in ["/tmp/caelestia-desktop-mapping.json", "/tmp/caelestia-desktop-windows.json"]:
        if os.path.exists(f):
            os.remove(f)

    if not windows:
        return

    # Restore each window to its original workspace on its original monitor
    for entry in windows:
        addr = entry[0]
        orig_ws = entry[1] if len(entry) > 1 else ws_id
        orig_mon = entry[3] if len(entry) > 3 else None
        if orig_mon:
            hyprctl("dispatch", "focusmonitor", orig_mon)
        hyprctl("dispatch", f"movetoworkspacesilent {orig_ws},address:{addr}")
        time.sleep(0.05)

if __name__ == "__main__":
    if os.path.exists(STATE_FILE):
        restore()
    else:
        show_desktop()
